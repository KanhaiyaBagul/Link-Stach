{
  "name": "LinkStash",
  "version": "1.0.0",
  "description": "Save, organize, and find any link instantly",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "identity",
    "bookmarks",
    "notifications",
    "offscreen",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseapp.com https://openrouter.ai;"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://*.firebaseapp.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://accounts.google.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "js/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "commands": {
    "quick-save": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Quickly save the current tab to LinkStash"
    }
  }
}
